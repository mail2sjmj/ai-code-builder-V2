# ── Git / commit script ──────────────────────────────────────────────────────
# Name of this repository (used by scripts/commit.sh to guard against
# accidental runs in the wrong repo).
REPO_NAME=ai-code-builder-V2

# Default branch that feature branches are merged into.
MAIN_BRANCH=main
